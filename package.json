{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/enforce-pnpm.mjs",
    "dev": "node ./scripts/start-dev.mjs",
    "dev:studio": "pnpm --filter insta-studio dev",
    "dev:api": "pnpm --filter ai-orchestrator-api dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:studio": "pnpm --filter insta-studio build",
    "build:api": "pnpm --filter ai-orchestrator-api build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "pg": "^8.20.0",
    "prettier": "^3.8.1",
    "puppeteer": "^24.40.0",
    "typescript": "~5.9.2"
  }
}
